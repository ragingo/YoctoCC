#!/bin/sh
#
# pre-commit hook: ステージされた C/C++ ファイルを clang-format でチェック
#

if ! command -v clang-format >/dev/null 2>&1; then
    echo "WARNING: clang-format not found, skipping format check"
    exit 0
fi

# ステージされた .cpp / .hpp ファイルを取得 (削除されたファイルは除外)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.cpp' '*.hpp')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FAILED=0

for FILE in $STAGED_FILES; do
    # ステージされた内容に対してフォーマットチェック
    if ! git show ":$FILE" | clang-format --assume-filename="$FILE" --dry-run --Werror 2>/dev/null; then
        echo "  $FILE"
        FAILED=1
    fi
done

if [ "$FAILED" -eq 1 ]; then
    echo ""
    echo "Format check failed. Run 'make format' to fix, then re-stage."
    exit 1
fi
